plugin {
    borders-plus-plus {
        add_borders = 1
        col.border_1 = rgba(00000033)
        border_size_1 = 2
    }

    hyprexpo {
        columns = 3
        gap_size = 5
        bg_col = rgba(f0f0f0cc)
        workspace_method = center current
        enable_gesture = true
	gesture_distance = 300        
        #gesture_positive = true
    }

    hyprfocus {
        enabled = yes
        focus_animation = flash
        flash {
            flash_opacity = 0.95
            in_bezier = linear
            in_speed = 0.5
            out_bezier = linear
            out_speed = 1.0
        }
    }
}
